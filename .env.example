# ─── Supabase ────────────────────────────────────────────────────────────────
# Settings → Database → Connection string → Transaction pooler (porta 6543)
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Settings → API → URL
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"

# Settings → API → anon public key (seguro para expor no browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Settings → API → service_role key (NUNCA expor no browser — só server-side)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ─── Email (Supabase já envia emails de auth, mas para contactos usa SMTP) ───
# Opção 1: Gmail App Password
# Opção 2: Resend.com (recomendado — free tier generoso)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASS="re_xxxxxxxxxxxx"
CONTACT_EMAIL="diogo@mediabraza.com"

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://mediabraza.com"

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
